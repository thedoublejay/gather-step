---
const packs = [
  {
    tag: 'plan.pack',
    heading: 'Plan pack',
    body:
      'Entry points, cross-repo dependency chains, migration siblings, generated probe plans, and affected event surface.',
    meta: 'Returns ~8K tokens · shaped for the planning step.',
  },
  {
    tag: 'debug.pack',
    heading: 'Debug pack',
    body:
      'Hotspot history, recent co-changes, ownership, upstream producers, downstream consumers.',
    meta: 'Returns ~8K tokens · shaped for the debugging step.',
  },
  {
    tag: 'fix.pack',
    heading: 'Fix pack',
    body:
      'Narrow edit surface, direct callers, likely tests, unresolved gaps, and the smallest safe path to a targeted change.',
    meta: 'Returns ~8K tokens · shaped for the implementation step.',
  },
  {
    tag: 'review.pack',
    heading: 'Review pack',
    body:
      'Blast radius for this diff, convention checks, contract drift, cross-repo impact.',
    meta: 'Returns ~8K tokens · shaped for the review step.',
  },
  {
    tag: 'change-impact.pack',
    heading: 'Change-impact pack',
    body:
      'Confirmed and probable downstream repos, field-impact gaps, optional payload drift hints, and ranked files for API or contract changes.',
    meta: 'Returns ~8K tokens · shaped for rollout planning.',
  },
  {
    tag: 'qa-evidence.manifest',
    heading: 'QA evidence manifest',
    body:
      'Canonical evidence rows, structured citations, existing-test signals, feature-flag gaps, and scan-limit gaps for downstream QA planning.',
    meta: 'Emits qa-evidence.v1 · shaped for test planning.',
  },
];
---

<section class="bp-sec" id="packs">
  <div class="bp-sec__head">
    <span class="bp-sec__num">DET-05 · Task-shaped, not dump-the-graph</span>
    <h2 class="bp-h2">Packs and evidence exports, shaped to the step <span class="u">you're on.</span></h2>
    <p class="bp-lede">
      Precision over noise. Six task-shaped exports cover planning, debugging, fixing, review, change impact, and QA evidence;
      the QA evidence manifest exports the facts a downstream planning tool needs.
    </p>
  </div>
  <div class="bp-packs">
    {
      packs.map((pack) => (
        <div class="bp-pack">
          <span class="bp-pack__tag">{pack.tag}</span>
          <h3>{pack.heading}</h3>
          <p>{pack.body}</p>
          <div class="bp-pack__meta">{pack.meta}</div>
        </div>
      ))
    }
  </div>
</section>
