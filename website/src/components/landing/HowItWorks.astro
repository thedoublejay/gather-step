---
interface CodeLine {
  dim?: string;
  line?: string;
}

interface Step {
  num: string;
  heading: string;
  body: string;
  code: CodeLine[];
}

const steps: Step[] = [
  {
    num: '01 · INIT',
    heading: 'Let it guide workspace setup.',
    body:
      'The v2 init flow discovers repos, writes the workspace config, can index immediately, generate AI summary files, register Claude MCP settings, and hand off to watch mode.',
    code: [
      { dim: '# from your workspace root' },
      { line: 'gather-step init --index --generate-ai-files --setup-mcp local' },
    ],
  },
  {
    num: '02 · WATCH',
    heading: 'Keep the graph fresh.',
    body:
      'Run watch during active development, or let `init --watch` continue after the first index pass. The MCP server can also run with `--watch` in one process.',
    code: [
      { dim: '# incremental updates while you edit' },
      { line: 'gather-step watch' },
    ],
  },
  {
    num: '03 · SHIP',
    heading: 'Ask what actually matters.',
    body:
      'Every prompt arrives with structural ground truth. Blast radius. Event consumers. Ownership. Conventions. No more large exploratory prompts before the actual work starts.',
    code: [
      { dim: '# a question your AI can finally answer' },
      { line: 'claude: what breaks if I change order.created?' },
    ],
  },
];
---

<section class="bp-sec" id="how">
  <div class="bp-sec__head">
    <span class="bp-sec__num">DET-08 · From zero to answered questions</span>
    <h2 class="bp-h2">Initialize, watch, <span class="u">ask.</span></h2>
    <p class="bp-lede">No API keys. No account. No data leaves your machine.</p>
  </div>

  <div class="bp-how">
    {
      steps.map((step) => (
        <div class="bp-step">
          <span class="bp-step__num">{step.num}</span>
          <h3>{step.heading}</h3>
          <p>{step.body}</p>
          <div class="bp-step__code">
            {
              step.code.map((line) =>
                'dim' in line ? (
                  <div class="dim">{line.dim}</div>
                ) : (
                  <div>$ {line.line}</div>
                )
              )
            }
          </div>
        </div>
      ))
    }
  </div>
</section>
