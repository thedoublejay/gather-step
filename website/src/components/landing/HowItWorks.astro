---
interface CodeLine {
  dim?: string;
  line?: string;
}

interface Step {
  num: string;
  heading: string;
  body: string;
  code: CodeLine[];
}

const steps: Step[] = [
  {
    num: '01 · INIT',
    heading: 'Let it guide workspace setup.',
    body:
      'From your workspace root, run `gather-step init` and follow the guided defaults. It discovers repos, writes the config, builds the first index, generates AI context files, and registers local Claude MCP settings.',
    code: [
      { dim: '# from your workspace root' },
      { line: 'cd /path/to/workspace' },
      { line: 'gather-step init' },
    ],
  },
  {
    num: '02 · INDEX',
    heading: 'Build the cross-repo graph.',
    body:
      'A full index walks every configured repo, parses TS / JS / Python / Rust / Go / Java, extracts framework structure, and writes the graph + search + metadata stores under `.gather-step/`. `--auto-recover` rebuilds stale generated state on the fly.',
    code: [
      { dim: '# initial or full reindex' },
      { line: 'gather-step index' },
    ],
  },
  {
    num: '03 · WATCH',
    heading: 'Keep the graph fresh.',
    body:
      'Watch mode incrementally re-indexes on every file save. `init --watch` continues after the first index pass, and `mcp serve --watch` runs the MCP server and watcher in a single process.',
    code: [
      { dim: '# incremental updates while you edit' },
      { line: 'gather-step watch' },
    ],
  },
  {
    num: '04 · ASK',
    heading: 'Ask what actually matters.',
    body:
      'Every prompt arrives with structural ground truth. Blast radius. Event consumers. Ownership. Conventions. No more large exploratory prompts before the actual work starts.',
    code: [
      { dim: '# a question your AI can finally answer' },
      { line: 'claude: what breaks if I change order.created?' },
    ],
  },
  {
    num: '05 · PACK',
    heading: 'Hand the graph to your assistant.',
    body:
      'Plan, debug, fix, review, and change-impact packs ship as one structured response. The MCP server makes them callable from Claude Code; the CLI emits the same JSON for any other tool.',
    code: [
      { dim: '# a planning pack for a target symbol' },
      { line: 'gather-step pack planning --target order.created' },
    ],
  },
  {
    num: '06 · REVIEW',
    heading: 'Review PRs with structural evidence.',
    body:
      'Run `gather-step pr-review` before merge to get a cross-repo surface delta: added and removed routes, exported symbols, payload contracts, event wiring, deployment surfaces, and removal risks — without sending code off-machine.',
    code: [
      { dim: '# review a branch against main' },
      { line: 'gather-step pr-review --base main --head feat/my-change' },
    ],
  },
];
---

<section class="bp-sec" id="how">
  <div class="bp-sec__head">
    <span class="bp-sec__num">DET-08 · From zero to answered questions</span>
    <h2 class="bp-h2">Init, index, watch, ask, pack, <span class="u">review.</span></h2>
    <p class="bp-lede">No API keys. No account. No data leaves your machine.</p>
  </div>

  <div class="bp-how">
    {
      steps.map((step) => (
        <div class="bp-step">
          <span class="bp-step__num">{step.num}</span>
          <h3>{step.heading}</h3>
          <p>{step.body}</p>
          <div class="bp-step__code">
            {
              step.code.map((line) =>
                'dim' in line ? (
                  <div class="dim">{line.dim}</div>
                ) : (
                  <div>$ {line.line}</div>
                )
              )
            }
          </div>
        </div>
      ))
    }
  </div>
</section>