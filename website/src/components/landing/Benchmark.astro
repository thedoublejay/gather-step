---
// Machine-time benchmark on a real 31-repo workspace (Apple M5 Pro,
// Rust 1.94.1 release build, 14,296 files). For each task:
//   manual    = wall-clock to `rg -l <symbol> | xargs cat > /dev/null`
//               (median of three runs).
//   gatherStep = wall-clock to `gather-step pack <symbol>` against an
//                already-loaded index (median of three warm runs;
//                cold first-load adds 1–3 s on top).
// Both numbers are seconds. Human reading and reasoning time is not
// included — the chart compares the two indexing strategies on the
// same hardware, not human productivity.
const tasks = [
  {
    id: 'Frontend hook',
    title: 'Trace where a shared frontend auth hook is used.',
    manual: 0.79,
    gatherStep: 0.03,
  },
  {
    id: 'Event flow',
    title: 'Find every consumer of a Kafka event across services.',
    manual: 1.44,
    gatherStep: 0.03,
  },
  {
    id: 'Shared API',
    title: 'Plan a change to a cross-repo use-case class.',
    manual: 0.32,
    gatherStep: 0.03,
  },
];

const scale = [
  { label: 'Repos', value: '31' },
  { label: 'Files', value: '14.3K' },
  { label: 'Symbols', value: '216K' },
  { label: 'Edges', value: '484K' },
  { label: 'Cross-repo edges', value: '96K' },
];

const planningOracle = [
  { label: 'Scenarios', value: '25 / 25' },
  { label: 'Coverage', value: '1.000' },
  { label: 'Top-1 / Top-3', value: '1.000 / 1.000' },
  { label: 'p50 latency', value: '3 ms' },
  { label: 'p95 latency', value: '8 ms' },
  { label: 'p99 latency', value: '15 ms' },
];

const totalManual = tasks.reduce((sum, task) => sum + task.manual, 0);
const totalGatherStep = tasks.reduce((sum, task) => sum + task.gatherStep, 0);
const maxBar = totalManual;
const speedup = (totalManual / totalGatherStep).toFixed(1);
---

<section class="bp-sec" id="benchmark">
  <div class="bp-bench">
    <div class="bp-bench__head">
      <div>
        <span class="bp-sec__num">DET-06 · Planning benchmark</span>
        <h2 class="bp-h2" style="margin-top: 12px;">
          Cross-repo planning, in <span class="u">milliseconds, not seconds.</span>
        </h2>
        <p class="bp-lede" style="margin-top: 14px;">
          Three planning tasks on the same 31-repo, 14,296-file workspace. Left bar is what
          a workspace-wide grep walk takes (`rg -l &lt;symbol&gt; | xargs cat`). Right bar is a
          single Gather Step pack query against the loaded index. Both measured wall-clock
          on the same machine; medians of three runs.
        </p>
      </div>
      <span class="bp-stamp">v3.5.2 · 2026-05-06</span>
    </div>

    <div class="bp-bench__hero">
      <div class="bp-bench__stat">
        <span class="bp-bench__stat__label">End-to-end machine time</span>
        <div class="bp-bench__stat__big">
          {speedup}×<span class="unit"> faster</span>
        </div>
        <div class="bp-bench__stat__small">
          <b>{totalManual.toFixed(2)}s</b> of unindexed grep, compressed into
          <b>{totalGatherStep.toFixed(2)}s</b> of pack queries on a warm index. Cold first-load
          adds 1–3 s on top; long-running MCP servers pay it once. Human reading and reasoning
          time is on top of the manual side, not the Gather Step side.
        </div>
      </div>

      <div class="bp-bench__chart" aria-label="Unindexed grep vs Gather Step pack query by task">
        {
          tasks.map((task) => (
            <div class="bp-bench__row">
              <div class="bp-bench__row__head">
                <b>{task.id}</b>
                <span class="bp-bench__speedup">{(task.manual / task.gatherStep).toFixed(1)}× faster</span>
              </div>
              <div class="bp-bench__bar">
                <div class="bp-bench__bar__fill bp-bench__bar__fill--manual" style={`width: ${(task.manual / maxBar) * 100}%`}></div>
                <span class="bp-bench__bar__val">{task.manual.toFixed(2)}s unindexed grep</span>
              </div>
              <div class="bp-bench__bar">
                <div
                  class="bp-bench__bar__fill bp-bench__bar__fill--gather-step"
                  style={`width: ${Math.max((task.gatherStep / maxBar) * 100, 8)}%`}
                ></div>
                <span class="bp-bench__bar__val">{task.gatherStep.toFixed(2)}s Gather Step pack</span>
              </div>
            </div>
          ))
        }
        <div class="bp-bench__legend">
          <span><i class="k-manual"></i>Unindexed grep walk</span>
          <span><i class="k-gather-step"></i>Gather Step pack query</span>
        </div>
      </div>
    </div>

    <div class="bp-bench__tasks">
      {
        tasks.map((task) => (
          <div class="bp-bench__task">
            <span class="bp-bench__task__tag">{task.id}</span>
            <h4>{task.title}</h4>
            <div class="bp-bench__task__row"><span>Unindexed grep</span><b>{task.manual.toFixed(2)}s</b></div>
            <div class="bp-bench__task__row"><span>Gather Step pack</span><b>{task.gatherStep.toFixed(2)}s</b></div>
          </div>
        ))
      }
    </div>

    <div class="bp-bench__scale">
      {
        scale.map((item) => (
          <div class="bp-bench__chip">
            <span class="bp-bench__chip__k">{item.label}</span>
            <span class="bp-bench__chip__v">{item.value}</span>
          </div>
        ))
      }
    </div>

    <div class="bp-bench__head" style="margin-top: 32px;">
      <div>
        <span class="bp-sec__num">Planning oracle (v3.5.2)</span>
        <p class="bp-lede" style="margin-top: 12px;">
          Full 25-scenario suite, every metric at the HIGH ceiling, latency well under release-gate thresholds (p50 ≤ 50 ms, p95 ≤ 300 ms, p99 ≤ 1000 ms).
        </p>
      </div>
    </div>
    <div class="bp-bench__scale">
      {
        planningOracle.map((item) => (
          <div class="bp-bench__chip">
            <span class="bp-bench__chip__k">{item.label}</span>
            <span class="bp-bench__chip__v">{item.value}</span>
          </div>
        ))
      }
    </div>

    <div class="bp-bench__note">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex: 0 0 auto; margin-top: 2px;">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
      <div>
        <b>Methodology.</b> Three planning targets on the same workspace:
        <code>useAuth</code> (220 referencing files), <code>CommentCreatedEvent</code> (66
        files), and <code>CreateTaskUseCase</code> (17 files). For each, the manual baseline
        runs <code>rg -l &lt;symbol&gt; | xargs cat</code> end-to-end; the Gather Step
        baseline runs <code>gather-step pack &lt;symbol&gt;</code> against an already-loaded
        index. Both wall-clock, both medians of three runs, both on the same Apple M5 Pro.
      </div>
    </div>
  </div>
</section>
