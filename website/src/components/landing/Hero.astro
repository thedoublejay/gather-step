---
const stats = [
  {
    label: 'Spec · Indexed',
    value: '26 repos · 13,604 files · 171,124 symbols · 405,384 edges · 88,365 cross-repo',
  },
  {
    label: 'Spec · Release',
    value: 'v3.5 ready · Oxc TS/JS parser · indexing perf + storage compactions · deployment topology · pr-review mode',
  },
  {
    label: 'Spec · Deployment',
    value: 'Local binary · guided MCP setup · Homebrew release automation · nothing leaves your machine',
  },
];
---

<section class="bp-hero">
  <div>
    <span class="bp-kicker"><i></i>The code graph for AI coding assistants</span>
    <h1 class="bp-hero__title">
      Gather context<br />
      <span class="u">before the move.</span>
    </h1>
    <p class="bp-hero__sub">
      One unified graph across your repos, not a federation of isolated ones.
      Built for teams running many services as one system.
    </p>
  </div>
  <div class="bp-hero__callouts">
    {
      stats.map((stat) => (
        <div class="bp-callout">
          <div class="bp-cell-k">{stat.label}</div>
          <div class="bp-cell-v">{stat.value}</div>
        </div>
      ))
    }
  </div>
</section>

<button
  type="button"
  class="bp-cli"
  data-copy-command="brew install thedoublejay/tap/gather-step"
  aria-label="Copy install command"
>
  <span class="arrow">▶</span>
  <span class="bp-cli__command">brew install thedoublejay/tap/gather-step</span>
  <span class="cursor"></span>
  <span class="stamp-inline" aria-live="polite">DET-01 · INSTALL</span>
</button>

<script>
  const copyButtons = document.querySelectorAll('.bp-cli[data-copy-command]');

  copyButtons.forEach((button) => {
    const feedback = button.querySelector('.stamp-inline');
    const defaultLabel = feedback?.textContent ?? '';

    button.addEventListener('click', async () => {
      const command = button.getAttribute('data-copy-command');
      if (!command || !feedback) return;

      try {
        await navigator.clipboard.writeText(command);
        button.classList.add('is-copied');
        feedback.textContent = 'COPIED';
      } catch {
        feedback.textContent = 'COPY FAILED';
      }

      window.setTimeout(() => {
        button.classList.remove('is-copied');
        feedback.textContent = defaultLabel;
      }, 1600);
    });
  });
</script>
