---
import Default from '@astrojs/starlight/components/Head.astro';

const { entry } = Astro.locals.starlightRoute;
const siteUrl = 'https://gatherstep.dev';
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;

const techArticle = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry.data.title,
  ...(entry.data.description ? { description: entry.data.description } : {}),
  url: pageUrl,
  mainEntityOfPage: pageUrl,
  inLanguage: 'en',
  isPartOf: { '@type': 'WebSite', name: 'Gather Step', url: siteUrl },
  author: { '@type': 'Person', name: 'JJ Adonis' },
  publisher: { '@type': 'Organization', name: 'Gather Step', url: siteUrl },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: entry.data.title, item: pageUrl },
  ],
};
---

<Default />
<script type="application/ld+json" is:inline set:html={JSON.stringify(techArticle)} />
<script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
